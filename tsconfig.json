{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vitest/globals"],
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": ["index.ts", "src/**/*.ts", "test/**/*.ts", "types/**/*.d.ts"]
}
